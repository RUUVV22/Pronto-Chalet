rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isBootstrapAdmin() {
      return isSignedIn() &&
        request.auth.token.email in ['islamalawneh4@gmail.com'];
    }

    function isAdmin() {
      return isSignedIn() &&
        (
          isBootstrapAdmin() ||
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        );
    }

    match /bookings/{bookingId} {
      allow read, create, update, delete: if isAdmin();
    }

    function isPublicAvailabilitySlot() {
      return request.resource.data.keys().hasOnly([
        'bookingDate',
        'bookingPeriod',
        'status',
        'updatedAt'
      ]) &&
        request.resource.data.bookingDate is string &&
        request.resource.data.bookingDate.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
        request.resource.data.bookingPeriod in ['morning', 'evening'] &&
        request.resource.data.status == 'booked' &&
        request.resource.data.updatedAt is timestamp;
    }

    match /publicAvailability/{slotId} {
      allow read: if true;
      allow create, update: if isAdmin() && isPublicAvailabilitySlot();
      allow delete: if isAdmin();
    }

    match /admins/{uid} {
      allow get: if (isSignedIn() && request.auth.uid == uid) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}
