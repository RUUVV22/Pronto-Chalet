[debug] [2026-07-13T08:13:29.561Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/prontochalet-f75b6/rulesets {"name":"projects/prontochalet-f75b6/rulesets/8bcb5e9c-f31c-4830-9aaa-c40b65588a84","source":{"files":[{"content":"rules_version = '2';\r\n\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n    function isSignedIn() {\n      return request.auth != null;\n    }\n\n    function isBootstrapAdmin() {\n      return isSignedIn() &&\n        request.auth.token.email in ['islamalawneh4@gmail.com'];\n    }\n\n    function isAdmin() {\n      return isSignedIn() &&\n        (\n          isBootstrapAdmin() ||\n          exists(/databases/$(database)/documents/admins/$(request.auth.uid))\n        );\n    }\n\r\n    match /bookings/{bookingId} {\r\n      allow read, create, update, delete: if isAdmin();\r\n    }\r\n\r\n    match /admins/{uid} {\r\n      allow get: if (isSignedIn() && request.auth.uid == uid) || isAdmin();\r\n      allow list: if isAdmin();\r\n      allow create, update, delete: if isAdmin();\r\n    }\r\n  }\r\n}\r\n","name":"firestore.rules"}]},"createTime":"2026-07-13T08:13:29.499599Z","metadata":{"services":["cloud.firestore"]}}
