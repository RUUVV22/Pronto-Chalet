{
  "name": "create-a-complete-chalet-booking-system",
  "version": "1.0.0",
  "private": true,
  "description": "A chalet booking system built with Node.js, Express, HTML, CSS, and vanilla JavaScript.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "firebase:login": "npx firebase-tools login",
    "firebase:deploy": "npx firebase-tools deploy",
    "firebase:deploy:hosting": "npx firebase-tools deploy --only hosting",
    "firebase:deploy:rules": "npx firebase-tools deploy --only firestore:rules",
    "firebase:migrate-bookings": "node work/migrate-bookings-to-firestore.mjs"
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.10"
  }
}
